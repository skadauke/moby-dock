# =============================================
# Moby Dock — Environment Variables
# =============================================
# Copy to .env.local and fill in your values.
# See README.md for setup instructions.

# GitHub OAuth (create at https://github.com/settings/developers)
GITHUB_ID=
GITHUB_SECRET=

# Session encryption secret (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=

# Allowed GitHub usernames (comma-separated)
ALLOWED_GITHUB_USERS=your-github-username

# Production URL (your Vercel deployment URL)
BETTER_AUTH_URL=https://your-app.vercel.app
NEXT_PUBLIC_AUTH_URL=https://your-app.vercel.app

# Home directory on the machine running the file server
NEXT_PUBLIC_HOME_DIR=/home/yourusername
HOME_DIR=/home/yourusername

# Supabase (create at https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# File server URL (your file server's public URL)
FILE_SERVER_URL=https://your-file-server.example.com
NEXT_PUBLIC_FILE_SERVER_URL=https://your-file-server.example.com
MOBY_FILE_SERVER_TOKEN=your-file-server-auth-token

# OpenClaw Gateway
CLAWDBOT_GATEWAY_URL=http://127.0.0.1:18789
CLAWDBOT_GATEWAY_TOKEN=

# Axiom logging (https://axiom.co)
NEXT_PUBLIC_AXIOM_TOKEN=
NEXT_PUBLIC_AXIOM_DATASET=

# API token for agent-to-dock communication
DOCK_API_TOKEN=

# Allowed file paths (comma-separated, ~ expands to home dir)
# Defaults to ~/clawd,~/clawd-dev,~/.openclaw,~/openclaw
# ALLOWED_FILE_PATHS=

# GitHub repo link in nav (defaults to https://github.com/skadauke/moby-dock)
# NEXT_PUBLIC_GITHUB_REPO=
